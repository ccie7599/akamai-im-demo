# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Akamai EdgeGrid (for purge/EW API calls from server)
EDGERC_PATH=~/.edgerc
EDGERC_SECTION=default

# DataStream 2 webhook auth
DS2_WEBHOOK_USERNAME=ds2-demo
DS2_WEBHOOK_PASSWORD=generate-secure-password

# Akamai property details (used by server API routes)
AKAMAI_PROPERTY_HOSTNAME=demo.example.com
AKAMAI_EDGEWORKER_ID=
AKAMAI_CP_CODE=

# API auth token (defense-in-depth for open port 443)
API_AUTH_TOKEN=generate-with-python3-c-import-secrets-secrets.token_urlsafe

# Frontend env vars (must be prefixed with VITE_)
VITE_AUTH_TOKEN=same-value-as-API_AUTH_TOKEN
VITE_AKAMAI_HOST=demo.example.com
VITE_ORIGIN_HOST=origin-demo.example.com
